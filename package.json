  "repository": {
    "type": "git",
    "url": "https://github.com/purrdict/hip4"
  },
  "license": "MIT",
  "author": "Purrdict <hello@purrdict.xyz>",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --outDir dist",
